# GoNZB Configuration Example

# The port the HTTP server will listen on
port: "8080"

# Hard module gates. These decide which backend/UI surfaces are loaded.
modules:
  downloader:
    enabled: true
  aggregator:
    enabled: true
  usenet_indexer:
    enabled: true
  gonzbnet:
    enabled: false
  web_ui:
    enabled: true
  api:
    enabled: true

# Browser and API clients authenticate with users, sessions, and account API tokens.
# Newznab/NZB clients should use a generated account API token as their `apikey`.
api:
  cors_allowed_origins:
    - "http://localhost:5173"
    - "http://127.0.0.1:5173"

# GoNZBNet federation is disabled by default. Phase 1 only creates a persistent
# node identity and signed append-only event primitives.
gonzbnet:
  mode: "integrated"
  node_alias: ""
  advertise_url: ""
  keys_dir: "data/gonzbnet/keys"
  spec_version: "gonzbnet/1.0"
  http_enabled: true
  http_base_path: "/gonzbnet/v1"
  private_network: true
  network_id: "default"
  local_pool_id: "pool.local"
  manual_peers: []
  consumer_enabled: true
  scanner_enabled: false
  index_projection_enabled: true
  manifest_builder_enabled: false
  manifest_cache_enabled: true
  validator_enabled: false
  health_checker_enabled: false
  coverage_enabled: false
  scheduler_enabled: false
  publish_release_cards_enabled: false
  publish_release_cards_batch_size: 50
  publish_release_cards_interval_minutes: 10
  manifest_availability_enabled: false
  health_attestations_enabled: false
  health_attestations_batch_size: 50
  health_attestations_interval_minutes: 30
  validation_batch_size: 25
  validation_interval_minutes: 15
  checksum_validation_enabled: false
  pull_sync_enabled: false
  pull_sync_interval_minutes: 10
  push_sync_enabled: false
  push_sync_interval_minutes: 10
  push_sync_batch_size: 100
  websocket_gossip_enabled: false
  gossip_interval_minutes: 1
  gossip_batch_size: 100
  gossip_ttl: 4
  gossip_fanout: 4
  peer_exchange_enabled: false
  relay_enabled: false
  relay_api_key: ""
  max_event_bytes: 262144
  max_manifest_bytes: 10485760
  max_batch_events: 100
  rate_limit_events_per_minute: 120
  time_tolerance_seconds: 120
  nonce_ttl_seconds: 600
  live_query_enabled: false
  send_user_context: false

# Operational settings are managed in the Admin UI and persisted to SQLite runtime settings.
# The legacy YAML keys below are intentionally omitted from the normal bootstrap example:
# - servers
# - indexers
# - aggregator.sources, including optional GoNZBNet federated cache search
# - download paths/options
# - indexing stage schedules/newsgroups/enrichment settings
# - release public-ready policy thresholds and release_generate_nzb/archive/purge stage controls
# - indexer PostgreSQL storage guard thresholds

# Application Logging
log:
  path: "gonzb.log" # Set to "" or "none" to disable file logging (recommended for Docker)
  level: "info"     # debug, info, warn, error
  include_stdout: true
  max_size_mb: 32   # Rotate active log file after this size.
  max_backups: 5    # Keep this many rotated files: gonzb.log.1, gonzb.log.2, ...

# Bootstrap storage. SQLite path stores queue/settings metadata; blob_dir is the single
# filesystem root for cached and archived NZBs.
store:
  sqlite_path: "/store/metadata/gonzb.db" # Database for releases and queue
  blob_dir: "/store/nzbs"                # Cache root; archives live under /store/nzbs/indexer-archive
  payload_cache_enabled: true # false = ephemeral (non-persistent) payload mode
  search_persistence_enabled: true # false = ephemeral (non-persistent) aggregator results
  
  # PostgreSQL DSN for the Usenet/NZB Indexer module when modules.usenet_indexer.enabled is true.
  pg_dsn: "postgres://gonzb:gonzb@localhost:5432/gonzb?sslmode=disable"
  # Optional privileged PostgreSQL DSN for explicit offline maintenance commands only.
  # Do not use this DSN for serve/supervisor runtime.
  pg_maintenance_dsn: ""

# After first launch, create the initial admin user at /setup, then configure NNTP,
# aggregator sources, downloader paths, and indexer stages in /admin/settings.
