# GoNZB Configuration Example

# The port the HTTP server will listen on
port: "8080"

# Hard module gates. These decide which backend/UI surfaces are loaded.
modules:
  downloader:
    enabled: true
  aggregator:
    enabled: true
  usenet_indexer:
    enabled: true
  web_ui:
    enabled: true
  api:
    enabled: true

# API authentication (optional)
api:
  key: "" # Set to a non-empty value to require apikey on /api and /nzb routes
  cors_allowed_origins:
    - "http://localhost:5173"
    - "http://127.0.0.1:5173"

# Operational settings are managed in the Admin UI and persisted to SQLite runtime settings.
# The legacy YAML keys below are intentionally omitted from the normal bootstrap example:
# - servers
# - indexers
# - aggregator.sources
# - download paths/options
# - indexing stage schedules/newsgroups/enrichment settings
# - release public-ready policy thresholds and release_generate_nzb/archive/purge stage controls
# - indexer PostgreSQL storage guard thresholds

# Application Logging
log:
  path: "gonzb.log" # Set to "" or "none" to disable file logging (recommended for Docker)
  level: "info"     # debug, info, warn, error
  include_stdout: true
  max_size_mb: 32   # Rotate active log file after this size.
  max_backups: 5    # Keep this many rotated files: gonzb.log.1, gonzb.log.2, ...

# Bootstrap storage. SQLite path stores queue/settings metadata; blob_dir is the single
# filesystem root for cached and archived NZBs.
store:
  sqlite_path: "/store/metadata/gonzb.db" # Database for releases and queue
  blob_dir: "/store/nzbs"                # Cache root; archives live under /store/nzbs/indexer-archive
  payload_cache_enabled: true # false = ephemeral (non-persistent) payload mode
  search_persistence_enabled: true # false = ephemeral (non-persistent) aggregator results
  
  # PostgreSQL DSN for the Usenet/NZB Indexer module when modules.usenet_indexer.enabled is true.
  pg_dsn: "postgres://gonzb:gonzb@localhost:5432/gonzb?sslmode=disable"

# After first launch, create the initial admin user at /setup, then configure NNTP,
# aggregator sources, downloader paths, and indexer stages in /admin/settings.
