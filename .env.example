# Generate independent URL-safe values, for example: openssl rand -hex 32
POSTGRES_PASSWORD=
POSTGRES_APP_PASSWORD=

# Host user/group that should own files in the GoNZB volumes.
PUID=1000
PGID=1000

# The default publishes the UI only on this machine. Set 0.0.0.0 only when a
# trusted reverse proxy, firewall, or private network protects the service.
GONZB_BIND_ADDRESS=127.0.0.1
GONZB_PORT=8080
# Required before exposing an instance whose first administrator has not been
# created. Generate with: openssl rand -hex 32
GONZB_API_BOOTSTRAP_TOKEN=

# Copy config.yaml.example before changing hard module gates.
GONZB_CONFIG_PATH=./config.yaml.example
